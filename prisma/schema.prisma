// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum BuildStatus {
  ACTIVE
  ARCHIVED
}

enum ProductType {
  FITTED
  OVERSIZED
  CUSTOM
}

enum GarmentColor {
  BLACK
  WHITE
  CUSTOM
}

enum FabricType {
  ESSENTIALS_170
  SIGNATURE_200
  HEAVYWEIGHT_300
}

enum AssetStatus {
  PENDING_UPLOAD
  READY
  FAILED
}

enum PlacementType {
  LEFT_CHEST
  RIGHT_CHEST
  RIGHT_SLEEVE
  LEFT_SLEEVE
  CENTER_FRONT
  FULL_FRONT
  CENTER_BACK
  FULL_BACK
}

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  phone        String?   @unique
  passwordHash String?
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]

  builds       Build[]
  orders       Order[]
}

model Build {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  name      String?
  status    BuildStatus @default(ACTIVE)

  userId    String?
  user      User?       @relation(fields: [userId], references: [id])

  draft     BuildDraft?
  assets    Asset[]
  designs   Design[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model BuildDraft {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  buildId   String      @unique
  build     Build       @relation(fields: [buildId], references: [id], onDelete: Cascade)

  product   ProductType?
  color     GarmentColor?
  fabric    FabricType?
  quantity  Int         @default(1)

  customNotes    String?

  primaryAssetId String?
  primaryAsset   Asset? @relation("DraftPrimaryAsset", fields: [primaryAssetId], references: [id], onDelete: SetNull)

  @@index([product])
  @@index([color])
  @@index([fabric])
}

model Asset {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  buildId   String
  build     Build       @relation(fields: [buildId], references: [id], onDelete: Cascade)

  status    AssetStatus @default(PENDING_UPLOAD)

  fileName  String
  mimeType  String?
  sizeBytes Int?

  // Phase 5+
  storageKey String?
  url        String?

  usedAsPrimaryIn BuildDraft[] @relation("DraftPrimaryAsset")

  placements DesignPlacement[]

  @@index([buildId])
  @@index([status])
  @@index([createdAt])
}

model Design {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildId   String
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  name      String?

  placements DesignPlacement[]

  @@index([buildId])
  @@index([createdAt])
}

model DesignPlacement {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())

  designId  String
  design    Design        @relation(fields: [designId], references: [id], onDelete: Cascade)

  placement PlacementType

  assetId   String
  asset     Asset         @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([designId, placement])
  @@index([assetId])
  @@index([placement])
}

model Order {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  status    String      @default("draft")
  total     Int         @default(0)

  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  items     OrderItem[]

  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  qty       Int      @default(1)
  unitPrice Int      @default(0)

  @@index([orderId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}